   "source": [
    "import requests\n",
    "\n",
    "base_url = \"http://localhost:8002\"\n",
    "endpoint = f\"{base_url}/api/events/\"\n",
    "\n",
    "data = {\n",
    "    \"description\": \"this is a concert\",\n",
    "    \"page\": \"home\"\n",
    "    # optional, can remove this\n",
    "}\n",
    "\n",
    "response = requests.post(endpoint, json=data)\n",
    "response.json()"
   ],
